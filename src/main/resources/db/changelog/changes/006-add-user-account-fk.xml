<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <!-- Link users to an account -->
    <changeSet id="006" author="tiaan">
        <addColumn tableName="users">
            <column name="account_id" type="BIGINT"/>
        </addColumn>
        <addForeignKeyConstraint
                baseTableName="users"
                baseColumnNames="account_id"
                referencedTableName="accounts"
                referencedColumnNames="id"
                constraintName="fk_users_account"/>
        <createIndex indexName="idx_users_account_id" tableName="users">
            <column name="account_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
