<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="007" author="tiaan">
        <createTable tableName="brush_routines">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="person_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="times_per_day" type="INT" defaultValueNumeric="2">
                <constraints nullable="false"/>
            </column>
            <column name="morning_time" type="TIME"/>
            <column name="evening_time" type="TIME"/>
            <column name="notes" type="VARCHAR(500)"/>
            <column name="active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="brush_routines"
                baseColumnNames="user_id"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_brush_routines_user"
                onDelete="CASCADE"/>

        <createIndex indexName="idx_brush_routines_user_id" tableName="brush_routines">
            <column name="user_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
